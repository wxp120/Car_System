   <property name="styleSheet">
    <string notr="true">/* 1. 容器样式 (保持不变) */
#widget02 {
    background-color: rgba(30, 35, 45, 0.8);
    border-radius: 15px;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

/* 2. 关键修复：清除所有标签的默认黑色背景 */
QLabel {
    background: transparent;  /* 这是解决黑色块/边缘的核心 */
    border: none;
    color: #FFFFFF;
}

/* 3. 城市和温度文字 */
#labelCity {
    font-size: 24px;
    font-weight: bold;
}

#labelTmp {
    color: #FFD700;
    font-size: 70px;
    font-weight: bold;
}

/* 4. 其他辅助文字 */
#labelweatherType, #labelTempRange {
    color: #B0B0B0;
    font-size: 18px;
}

/* 5. 确保图标 Label 也是透明的 */
#labelWeatherIcon {
    background: transparent;
}</string>
