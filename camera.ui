  <property name="styleSheet">
   <string notr="true">/* ===== 主窗口全局 ===== */
#Camera {
    background-color: transparent; /* 保留背景图 */
    font-family: &quot;微软雅黑&quot;, &quot;思源黑体&quot;, sans-serif;
}

/* 全局所有文字 统一白色 */
QLabel {
    font-size: 16px;
    color: #ffffff;
}

/* ===== 左侧距离预警卡片 ===== */
#widget {
    background-color: transparent;
	border-radius: 14px;
    border: none;
}

/* 主标题 */
QLabel#label_title {
    font-size: 36px;
    font-weight: 900;
    color: #ffffff;
}

/* 标题：后方障碍物相对距离 */
QLabel#label_tips {
    font-size: 24px;
    font-weight: 700;
    color: #ffffff;
}

/* 核心超大距离数字 */
QLabel#label_distance {
    font-size: 72px;
    font-weight: 900;
    color: #ffffff;
}

/* 警示小字：距离过近 */
QLabel#tip_warning {
    font-size: 22px;
    font-weight: bold;
    color: #ffffff;
}

/* 底部状态：蜂鸣器：已启用 */
QLabel#status_buzzer {
    font-size: 16px;
    color: #ffffff;
}

/* ===== 右侧摄像头画面卡片 —— 新加高级半透明底色 ===== */
#widget_2 {
    background-color: rgba(30, 30, 50, 0.6); /* 半透深蓝灰底色 */
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.2); /* 柔和白边 */
}

/* 标题：倒车影像视频画面 */
QLabel#label_introduce {
    font-size: 26px;
    font-weight: 700;
    color: #ffffff;
}

/* 右上角：摄像头：未开启 */
QLabel#camera_status {
    font-size: 15px;
    color: #ffffff;
}

/* 视频预览黑屏区域 —— 加半透底色 */
#camera_widget {
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.3);
}

/* ===== 所有按钮样式 ===== */
QPushButton {
    background-color: #3498f0;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 10px 24px;
    font-size: 18px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #2187e0;
}

QPushButton:pressed {
    background-color: #1965c0;
}

/* 打开摄像头按钮 */
QPushButton#btn_camera_on {
    font-size: 18px;
    min-height: 42px;
}</string>
  </property>
