        <property name="styleSheet">
         <string notr="true">#card_weather {
    background-color: rgba(30, 35, 45, 0.5); 
    border-radius: 15px;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

/* 顺便把里面的文字设为白色，并居中 */
#card_weather QLabel {
    color: white;
    background: transparent;
    font-weight: bold;
}

/* 1. 温度：最醒目，大号字体 */
#lab_temp {
    color: white;
    background: transparent;
    font-size: 30px;
    font-weight: bold;
	qproperty-alignment: 'AlignLeft';
}

/* 2. 天气描述 (如: 多云)：中等字号，稍微暗一点点 */
#lab_weather_status {
    color: rgba(255, 255, 255, 210); /* 略带透明的白 */
    background: transparent;
    font-size: 30px;
    font-weight: bold;
	qproperty-alignment: 'AlignLeft';
}

/* 3. 城市名称 (如: 北京 昌平)：最小，最暗，拉开层级 */
#lab_city {
    font-size: 20px;
	background: transparent;
    color: rgba(255, 255, 255, 150); /* 比较明显的变暗效果 */
	font-weight: bold;
    qproperty-alignment: 'AlignCenter';
}</string>
