    <property name="styleSheet">
     <string notr="true">/* 选中这三个标签的通用样式 */
#indictor1, #indictor2, #indictor3 {
    border: none;
    /* 1. 设置颜色：默认灰色 (未选中状态) */
    background-color: rgba(255, 255, 255, 30);
    /* 2. 设置圆角：高度的一半 */
    border-radius: 4px;
    /* 3. 固定大小：长条需要固定高度和宽度 */
    min-width: 40px;
    max-width: 40px;
    min-height: 8px;
    max-height: 8px;
}

#indictor1 {
    background-color: rgb(255, 255, 255);
}</string>
