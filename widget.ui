        <property name="styleSheet">
         <string notr="true">#card_clock {
    /* 保持原状，仅修改背景色，使用带透明度的深蓝/黑色调 */
    background-color: rgba(30, 35, 45, 0.5); 
    border-radius: 15px;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

/* 顺便把里面的文字设为白色，并居中 */
#card_clock QLabel {
    color: white;
    background: transparent;
}

/* --- 在原有基础上添加以下内容 --- */

/* 针对时间：大、粗、醒目 */
#timeLabel {
    font-size: 40px;           /* 足够大的数字才有科技感 */
    font-weight: bold;         /* 加粗 */
    margin-bottom: 2px;        /* 压缩和日期之间的间距 */
    qproperty-alignment: 132;  /* 强制居中 (AlignHCenter | AlignVCenter) */
}

/* 针对日期：小、细、半透明 */
#dateLabel {
    font-size: 25px;
    color: rgba(255, 255, 255, 150); /* 半透明白，拉开层级 */
    margin-top: 0px;
    qproperty-alignment: 132;  /* 强制居中 */
}</string>
        </property>
