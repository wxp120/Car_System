  <property name="styleSheet">
   <string notr="true">/* 1. 设置主窗口背景，使用 #Widget 锁定对象名，防止子控件继承背景 */
#Widget {
    background-image: url(:/background2.png);
    background-position: center;
    background-repeat: no-repeat;
}

/* 2. 侧边栏：只保留必要的装饰，移除 max-width 限制 */
#widget {
    background-color: rgba(15, 20, 35, 180);
    border-top-right-radius: 15px;
    border-bottom-right-radius: 15px;
}

/* 3. 侧边栏内的按钮：移除固定宽高，交给布局控制，仅保留交互反馈 */
#widget QPushButton {
    background: transparent;
    border: none;
    padding: 5px;
}

QPushButton:pressed {
    background-color: rgba(255, 255, 255, 30);
    border-radius: 5px;
}

/* 4. 文字标签：透明背景，白色文字 */
QLabel {
    color: #ffffff;
    font-size: 12px;
    background: transparent;
}

/* 5. 关键：强制让堆栈窗口及其页面透明，否则它们会遮挡主窗口背景图 */
QStackedWidget, QStackedWidget &gt; QWidget {
    background: transparent;
}

#lab_nav_text, #lab_video_text, #lab_apps_text, #lab_radio_text, #lab_settings_text {
    color: #ffffff;
    font-size: 12px;
    background: transparent;
    /* 核心代码：设置 Qt 属性实现水平和垂直双向居中 */
    qproperty-alignment: 'AlignHCenter | AlignVCenter';
    padding: 0px;
}</string>
  </property>
