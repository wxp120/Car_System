    <widget class="QCalendarWidget" name="calendarWidget">
     <property name="geometry">
      <rect>
       <x>190</x>
       <y>30</y>
       <width>581</width>
       <height>301</height>
      </rect>
     </property>
     <property name="styleSheet">
      <string notr="true">/* 日历最外层容器 */
QCalendarWidget {
    background-color: #2B2B2B;
}

/* 顶部导航栏（年月+左右箭头） */
QCalendarWidget QWidget#qt_calendar_navigationbar {
    background-color: #3C3C3C;
}

/* 顶部左右切换箭头按钮 */
QCalendarWidget QToolButton {
    color: #FFFFFF;
    background-color: #4A4A4A;
    font-size: 14px;
    border: none;
}
QCalendarWidget QToolButton:hover {
    background-color: #5A5A5A;
}

/* 年月标题文字 */
QCalendarWidget QLabel {
    color: #FFFFFF;
}

/* 核心修复：强制整个日历表格+所有单元格容器 全深色兜底，消灭中间黑块 */
QCalendarWidget QTableView,
QCalendarWidget QTableView &gt; QWidget,
QCalendarWidget QAbstractItemView {
    background-color: #2B2B2B;
    alternate-background-color: #2B2B2B;
    color: #FFFFFF;
    selection-background-color: #0078D7;
    selection-color: #FFFFFF;
    gridline-color: #444444;
    outline: none;
}

/* 周表头（星期几文字） */
QCalendarWidget QHeaderView::section {
    background-color: #3C3C3C;
    color: #FFFFFF;
    font-weight: bold;
    font-size: 14px;
    padding: 6px;
    border: none;
}
/* 周末表头标红 */
QCalendarWidget QHeaderView::section:first-child,
QCalendarWidget QHeaderView::section:last-child {
    color: #FF4444;
}

/* 普通日期格子 */
QCalendarWidget QTableView::item {
    color: #FFFFFF;
    padding: 6px;
    min-width:40px;
    min-height:35px;
}

/* 周末日期标红 和截图效果一致 */
QCalendarWidget QTableView::item:weekday(1),
QCalendarWidget QTableView::item:weekday(7) {
    color: #FF4444;
}

/* 选中日期高亮 */
QCalendarWidget QTableView::item:selected {
    background-color: #0078D7;
    color: white;
    font-weight:bold;
}

/* 其他月份灰色日期 */
QCalendarWidget QTableView::item:disabled {
    color: #666666;
}

/* 鼠标悬停 */
QCalendarWidget QTableView::item:hover:!selected {
    background-color:#454545;
    border-radius:2px;
}

/* 今日日期标记 */
QCalendarWidget QTableView::item:today {
    border:1px solid #0078D7;
}

/* ===================== 终极修复：月份 / 年份 下拉弹窗 100% 解决黑底 ===================== */
QCalendarWidget QComboBox {
    background-color: #3C3C3C;
    color: #FFFFFF;
    border: none;
}
QCalendarWidget QComboBox::drop-down {
    border: none;
}
QCalendarWidget QComboBox::view {
    background-color: #2B2B2B;
    color: #FFFFFF;
    border: 1px solid #444444;
}
QCalendarWidget QComboBox::item {
    background-color: #2B2B2B;
    color: #FFFFFF;
    padding: 6px 12px;
}
QCalendarWidget QComboBox::item:selected {
    background-color: #0078D7;
    color: #FFFFFF;
}
QCalendarWidget QComboBox::item:hover {
    background-color: #444444;
}</string>
     </property>
    </widget>
