  <property name="styleSheet">
   <string notr="true">/* 1. 统一面板样式 */
QWidget#leftPanel {
    background-color: #2b2b2b;
    border-radius: 10px;
    padding: 10px;
}

/* 2. 文本框容器样式 (解决了图标和文本对齐问题) */
QLineEdit {
    background-color: #1e1e1e;
    color: #ffffff;
    border: 1px solid #ffaa00; /* 橙色边框 */
    border-radius: 8px;
    height: 50px;
    font-size: 16px;
}

/* 3. 导航按钮样式 */
QPushButton#startNavBtn {
    background-color: #333333;
    color: #ffaa00;
    font-weight: bold;
    border: 1px solid #444;
    border-radius: 10px;
    height: 80px;
    font-size: 18px;
}
QPushButton#startNavBtn:pressed {
    background-color: #444444;
}

/* 4. 辅助文本 (距离/时间) */
QLabel#distLabel, QLabel#timeLabel {
    color: #cccccc;
    font-size: 14px;
    margin: 5px 0;
}

/* 5. 底部按钮组样式 */
QPushButton#zoomInBtn, QPushButton#zoomOutBtn, QPushButton#resetBtn {
    background-color: #3d3d3d;
    color: white;
    border-radius: 5px;
    height: 40px;
}
</string>
