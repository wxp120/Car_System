  <property name="styleSheet">
   <string notr="true">/* 1. 设置主背景色 */
#musicplayer {
    background-color: rgb(35, 35, 40);
}

QLabel {
    color: white;
    font-size: 18px;
    font-weight: bold;
    font-family: 'Microsoft YaHei', sans-serif;
    
    /* 添加这一行实现居中 */
    qproperty-alignment: 'AlignCenter'; 
}

/* 3. 列表背景透明，去掉边框 */
QListWidget {
    background-color: transparent;
    border: none;
    outline: 0px;
}

/* 4. 列表项文字颜色和间距 */
QListWidget::item {
color: rgb(200, 200, 200);
    padding: 12px;           /* 增加内边距，让列表看起来更舒展 */
    font-size: 18px;         /* 这里设置字体大小，你可以根据需要调整为 16px 或 20px */
    font-weight: bold;       /* 加粗，在车载屏幕上更清晰 */
}

/* 5. 选中项的样式（高亮显示） */
QListWidget::item:selected {
    background-color: rgb(50, 150, 255); /* 选中时的蓝色背景 */
    color: white;                       /* 选中后的文字颜色 */
    border-radius: 8px;                 /* 选中项的圆角 */
}

QPushButton:hover {
    background-color: rgba(255, 255, 255, 30); 
}
QSlider::groove:horizontal {
    height: 4px;
    background: rgba(255, 255, 255, 50); /* 半透明轨道 */
    border-radius: 2px;
}
QSlider::handle:horizontal {
    width: 12px;
    height: 12px;
    background: white;
    margin: -4px 0; /* 让滑块居中 */
    border-radius: 6px;
}
#listWidget_lrc{
    color: white;
    font-size: 30px;            /* 这里设置你想要的大小 */
    font-weight: bold;
    
}
</string>
  </property>
