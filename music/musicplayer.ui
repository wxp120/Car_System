   <property name="styleSheet">
    <string notr="true">/* 针对控件本身的设置 */
QListWidget {
    background-color: transparent;
    border: none;
    outline: 0;
}

/* 针对每一行歌词的设置 */
QListWidget::item {
    color: rgba(255, 255, 255, 150); 
    font-size: 40px;    /* 调大至 40px */
    height: 60px;      /* 必须同步增加高度，防止被截断 */
    padding-left: 20px; /* 增加左侧间距，避免文字紧贴边缘 */
}

/* 针对选中行（当前歌词）的设置 */
QListWidget::item:selected {
    color: #00FFCC; 
    font-size: 50px;    /* 选中的当前行更突出，调至 50px */
    font-weight: bold;
    background-color: transparent;
}</string>
